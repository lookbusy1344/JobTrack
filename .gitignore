# General build/IDE artifacts (previously inherited from the parent VSStuff/.gitignore;
# rolled in here so this file is self-contained if the project moves out of the monorepo).
bin/
obj/
.vs/
*.csproj.user
*.DotSettings.user
.DS_Store
copilotDiffState.xml
copilot.data.*.xml
*.bak

# Client-side dependencies restored (not authored) into the web project — e.g. via LibMan
# or npm once Bootstrap is pinned per impl plan §8.1. Vendor bundles and their source maps
# are not source.
src/JobTrack.Web/wwwroot/lib/
*.min.js.map
*.min.css.map

# Test run output (coverlet.collector is referenced by every test project; a coverage-collecting
# run drops trx/coverage files here, not source).
TestResults/
*.trx

# SQLite scratch databases created by manual runs or misconfigured local test fixtures — the
# provider conformance suite (impl plan §6.4) is expected to use temp paths, not the repo tree.
# Deliberately NOT "*.sqlite": that suffix matches the JobTrack.Persistence.Sqlite project
# directory itself case-insensitively and silently swallows the whole project.
*.db
*.db-shm
*.db-wal
*.sqlite3

# Snapshot-testing "received" output (e.g. Verify), if adopted for public API approval tests
# (impl plan §7.5) — only the paired *.verified.* baseline is meant to be committed.
*.received.*

# Local secret/connection-string overrides — never committed, regardless of environment.
appsettings.*.local.json
secrets.json

# Stryker.NET mutation-testing report/log output (impl plan §7.5) — regenerated by
# `dotnet-stryker` (global tool), not source.
StrykerOutput/
