{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-net/master/src/Stryker.Core/Stryker.Core/Testing/schema/stryker-config-schema.json",
  "stryker-config": {
    "mutate": [
      "Intervals/IntervalAlgebra.cs",
      "Intervals/WorkInterval.cs",
      "Schedules/WeeklyInterval.cs",
      "Authorization/*.cs",
      "Hierarchy/PrerequisiteEdge.cs",
      "Hierarchy/UnsatisfiedPrerequisite.cs",
      "Hierarchy/ReadinessResult.cs",
      "Hierarchy/ReadinessCalculator.cs",
      "Costing/*.cs",
      "Rates/UserCostRate.cs"
    ],
    "test-projects": [
      "../../tests/JobTrack.Domain.Tests/JobTrack.Domain.Tests.csproj"
    ],
    "reporters": [
      "html",
      "progress",
      "cleartext"
    ],
    "thresholds": {
      "high": 80,
      "low": 75,
      "break": 75
    }
  }
}
