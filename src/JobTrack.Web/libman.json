{
  "version": "1.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "provider": "cdnjs",
      "library": "twitter-bootstrap@5.3.3",
      "destination": "wwwroot/lib/bootstrap/",
      "files": [
        "css/bootstrap.min.css",
        "css/bootstrap.min.css.map",
        "js/bootstrap.bundle.min.js",
        "js/bootstrap.bundle.min.js.map"
      ]
    },
    {
      "provider": "jsdelivr",
      "library": "@fontsource/mulish@5.2.8",
      "destination": "wwwroot/lib/mulish/",
      "files": [
        "files/mulish-latin-400-normal.woff2",
        "files/mulish-latin-600-normal.woff2",
        "files/mulish-latin-700-normal.woff2",
        "files/mulish-latin-800-normal.woff2"
      ]
    }
  ]
}
