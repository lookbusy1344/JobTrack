@using JobTrack.Abstractions
@model AchievementIconModel
@{
	@* Cancelled and Unsuccessful share the "closed unfinished" glyph but keep their own words: the
	   distinction is real (withdrawn vs. attempted and failed) and survives in the label, it just
	   isn't worth a second silhouette a reader has to learn to tell apart at 16px.

	   None and null both mean "no achievement recorded" — a branch, or a leaf without leaf work — and
	   render nothing at all. Drawing a glyph for the absence of a state would put a mark on almost
	   every branch row in a healthy tree, which is exactly the noise the blocked marker avoids. *@
	var glyph = Model.Achievement switch {
		Achievement.Waiting => ("jt-icon-achievement-waiting", "waiting"),
		Achievement.InProgress => ("jt-icon-achievement-in-progress", "in-progress"),
		Achievement.Success => ("jt-icon-achievement-success", "success"),
		Achievement.Cancelled or Achievement.Unsuccessful => ("jt-icon-achievement-closed", "closed"),
		Achievement.None or null => default((string IconId, string Modifier)?),
		_ => throw new ArgumentOutOfRangeException(nameof(Model.Achievement), Model.Achievement, null),
	};
}
@* Both tests hold or neither does; the second binds the value the label needs. *@
@if (glyph is var (iconId, modifier) && Model.Achievement is { } achievement) {
	var label = EnumDisplay.Label(achievement);
	<span class="jt-achievement-icon jt-achievement-icon--@modifier">
		<svg class="jt-achievement-icon-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
			<use href="#@iconId"></use>
		</svg>
		@if (Model.ShowLabel) {
			<span class="jt-achievement-icon-label">@label</span>
		} else {
			<span class="visually-hidden">@label</span>
		}
	</span>
}
