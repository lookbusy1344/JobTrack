@model JobTrack.Domain.Hierarchy.ReadinessResult
@if (Model.IsReady) {
	<p class="status-pill status-pill-ready" role="status">
		<svg class="status-pill-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
			<use href="#jt-icon-go"></use>
		</svg>
		No blocks — every prerequisite is satisfied.
	</p>
} else {
	<p class="status-pill status-pill-blocked" role="alert">
		<svg class="status-pill-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
			<use href="#jt-icon-stop"></use>
		</svg>
		Blocked — unsatisfied prerequisites
	</p>
	<ul class="jt-list">
		@foreach (var blocker in Model.Blockers) {
			<li class="d-flex flex-wrap align-items-center justify-content-between gap-3">
				<span class="jt-tag">Job @blocker.RequiredJobId.Value</span>
				<span class="jt-muted">declared on job @blocker.DeclaredOnJobId.Value</span>
			</li>
		}
	</ul>
}
