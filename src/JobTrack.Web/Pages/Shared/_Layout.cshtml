@using JobTrack.Identity
@{
	var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;

	string NavState(string prefix, params string[] excludedPrefixes) =>
		currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
		&& Array.TrueForAll(excludedPrefixes, excluded => !currentPage.StartsWith(excluded, StringComparison.OrdinalIgnoreCase))
			? "active"
			: string.Empty;
}
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8"/>
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
	<meta name="theme-color" content="#1a1109"/>
	<title>@ViewData["Title"] - JobTrack</title>
	@* Preload the workhorse display weight (h1/brand) so headings settle without a fallback flash;
	   fonts are always fetched in CORS mode, so the crossorigin attribute is required even same-origin. *@
	<link rel="preload" href="~/lib/mulish/files/mulish-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin/>
	<link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css"/>
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
	<link rel="stylesheet" href="~/JobTrack.Web.styles.css" asp-append-version="true"/>
</head>
<body>
<partial name="_IconSprite"/>
<header class="app-header">
	<nav class="navbar navbar-expand-sm navbar-dark">
		<div class="container">
			<a class="navbar-brand" asp-area="" asp-page="/Index">
				<span class="jt-brand-mark" aria-hidden="true">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
					     stroke-linejoin="round">
						<path
							d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
					</svg>
				</span>
				<span>JobTrack</span>
			</a>
			<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
			        aria-controls="navbarSupportedContent"
			        aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
				<ul class="navbar-nav flex-grow-1">
					@if (User.IsInRole(EmployeeRoleNames.Requester)) {
						<li class="nav-item">
							<a class="nav-link @NavState("/Requests")" asp-area="" asp-page="/Requests/Index">My requests</a>
						</li>
					} else if (User.Identity?.IsAuthenticated == true) {
						<li class="nav-item">
							<a class="nav-link @NavState("/Jobs", "/Jobs/AwaitingProgress")" asp-area="" asp-page="/Jobs/Browse">Jobs</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-area="" asp-page="/Jobs/Browse">Root</a>
						</li>
						<li class="nav-item">
							<a class="nav-link @NavState("/Jobs/AwaitingProgress")" asp-area="" asp-page="/Jobs/AwaitingProgress">Awaiting
								progress</a>
						</li>
						<li class="nav-item">
							<a class="nav-link @NavState("/Rota")" asp-area="" asp-page="/Rota/Index">Rota</a>
						</li>
					}
				</ul>
				<ul class="navbar-nav align-items-sm-center">
					@if (User.Identity?.IsAuthenticated == true) {
						<li class="nav-item">
							<span class="jt-user" title="Signed in">@User.Identity.Name</span>
						</li>
						<li class="nav-item">
							<a class="nav-link @NavState("/Account/PersonalAccessTokens")" asp-page="/Account/PersonalAccessTokens">API tokens</a>
						</li>

						<li class="nav-item">
							<a class="nav-link @NavState("/Account/ManageTwoFactor")" asp-page="/Account/ManageTwoFactor">Two-factor</a>
						</li>
						<li class="nav-item">
							<form method="post" asp-page="/Account/Logout" class="inline-form" data-jt-clear-history-on-submit>
								<button type="submit" class="nav-link btn btn-link">Sign out</button>
							</form>
						</li>
					} else {
						<li class="nav-item">
							<a class="nav-link @NavState("/Account/Login")" asp-page="/Account/Login">Sign in</a>
						</li>
					}
					<li class="nav-item">
						<a class="jt-github-link" href="https://github.com/lookbusy1344/JobTrack" target="_blank" rel="noopener noreferrer"
						   title="JobTrack on GitHub" aria-label="JobTrack on GitHub">
							<svg class="jt-github-link-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
								<use href="#jt-icon-github"></use>
							</svg>
						</a>
					</li>
				</ul>
			</div>
		</div>
	</nav>
</header>
<div class="container">
	<main role="main">
		@RenderBody()
	</main>
</div>

<script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", false)
</body>
</html>
