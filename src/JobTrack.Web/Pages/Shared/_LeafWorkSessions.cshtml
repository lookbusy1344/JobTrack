@using System.Globalization
@model LeafWorkSessionsPanelModel

<form method="get" class="jt-form-card">
	@foreach (var field in Model.ExtraHiddenFields) {
		<input type="hidden" name="@field.Key" value="@field.Value"/>
	}
	<div class="form-group">
		<label for="WorkedByUserId">Filter by worker</label>
		<select id="WorkedByUserId" name="WorkedByUserId" class="form-control" asp-items="Model.WorkedByOptions"></select>
	</div>
	<button type="submit" class="btn btn-secondary">Apply filter</button>
</form>

@if (Model.DisplayedWorkedByName is { } displayedWorkedByName) {
	<h2>Sessions worked by @displayedWorkedByName</h2>
} else {
	<h2>Sessions</h2>
}
@if (Model.Sessions.Count == 0) {
	<p class="jt-empty">No sessions yet.</p>
} else {
	<div class="jt-table-scroll">
		<table class="table">
			<thead>
			<tr>
				<th>Worked by</th>
				<th>Started</th>
				<th>Finished</th>
				<th>Actions</th>
			</tr>
			</thead>
			<tbody>
			@foreach (var session in Model.Sessions) {
				var sessionBackdate = session.FinishedAt is null
					? new BackdateDisclosureModel {
						Handler = "Finish",
						FieldName = "finishedAt",
						Label = "Finished at",
						SubmitText = "Finish at this time",
						AccessibleName = "Backdate finish",
						HiddenFields = Model.SessionFields(session),
						RowId = $"backdate-finish-session-{session.Id.Value.ToString(CultureInfo.InvariantCulture)}",
					}
					: null;
				<tr>
					<td>@Model.DescribeWorker(session.WorkedByUserId)</td>
					<td>@InstantDisplay.Format(session.StartedAt, Model.ViewerZone)</td>
					<td>
						@if (session.FinishedAt is { } finishedAt) {
							@InstantDisplay.Format(finishedAt, Model.ViewerZone)
						} else {
							<span class="status-pill status-pill-ready">Active</span>
						}
					</td>
					<td>
						<div class="jt-toolbar d-flex flex-wrap gap-2 align-items-center">
							@if (sessionBackdate is not null) {
								<form method="post" asp-page-handler="Finish" class="inline-form">
									@foreach (var field in sessionBackdate.HiddenFields) {
										<input type="hidden" name="@field.Key" value="@field.Value"/>
									}
									<button type="submit" class="jt-icon-button" title="Finish / pause">
										<svg class="jt-icon-summary-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
											<use href="#jt-icon-finish"></use>
										</svg>
										<span class="visually-hidden">Finish / pause</span>
									</button>
								</form>
								<partial name="_BackdateTrigger" model="sessionBackdate"/>
							}
							@* The list can span several workers, so each row corrects its own worker's
							   session, not whoever the panel happens to be filtered to. *@
							<a asp-page="/Jobs/CorrectSession"
							   asp-route-leafNodeId="@Model.LeafNodeId"
							   asp-route-workedByUserId="@session.WorkedByUserId.Value"
							   asp-route-sessionId="@session.Id.Value">Correct</a>
						</div>
					</td>
				</tr>
				@if (sessionBackdate is not null) {
					<partial name="_BackdateRow" model="@(new BackdateRowModel { Disclosure = sessionBackdate, ColumnCount = 4 })"/>
				}
			}
			</tbody>
		</table>
	</div>
}
