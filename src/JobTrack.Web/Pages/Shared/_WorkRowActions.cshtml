@model WorkRowActionsModel
@* One leaf row's work controls, shared by every table listing leaves. Icon-only because this cell
   repeats once per row and labelled buttons in each would out-shout the row's own name; the
   standalone toolbar on Browse's node detail page keeps its labels.

   The "Active since"/count pill is deliberately *not* here — it has its own column
   (`_ActiveSincePill`). Sharing this cell made the buttons shift horizontally from row to row
   depending on whether a session happened to be running, so the one control a reader is aiming for
   never sat still.

   Never infers a target worker from collection order (plan §2.4): the viewer's own action always
   comes from Model.ViewerSession, and "Start for…" is a distinct disclosure from the viewer's own
   one-click Start. When exactly one session is active and it belongs to someone else, a permitted
   manager still finishes it inline (Model.SoloOtherSession) -- one session is unambiguous. But with
   two or more workers, a finish button per worker turns the cell into a confusing, unbounded row, so
   every other worker's session is delegated to the leaf's own Sessions page (the always-present link
   below), where each session has its own control. *@
<div class="jt-toolbar d-flex flex-nowrap justify-content-end gap-2 align-items-center">
	@if (Model.ViewerSession is { } viewerSession) {
		<form method="post" asp-page-handler="Finish" class="inline-form">
			@foreach (var field in Model.FinishFieldsFor(viewerSession)) {
				<input type="hidden" name="@field.Key" value="@field.Value"/>
			}
			<button type="submit" class="jt-icon-button" title="Finish / pause">
				<svg class="jt-icon-summary-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
					<use href="#jt-icon-finish"></use>
				</svg>
				<span class="visually-hidden">Finish / pause</span>
			</button>
		</form>
		<partial name="_BackdateTrigger" model="Model.FinishBackdateFor(viewerSession)"/>
	} else if (!Model.IsStartClosed) {
		<form method="post" asp-page-handler="@Model.StartHandler" class="inline-form">
			@foreach (var field in Model.StartFields) {
				<input type="hidden" name="@field.Key" value="@field.Value"/>
			}
			<button type="submit" class="jt-icon-button jt-icon-button--primary" title="Start session">
				<svg class="jt-icon-summary-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
					<use href="#jt-icon-start"></use>
				</svg>
				<span class="visually-hidden">Start session</span>
			</button>
		</form>
		<partial name="_BackdateTrigger" model="Model.StartBackdate"/>
	}
	@{ var soloOther = Model.SoloOtherSession; }
	@if (soloOther is not null) {
		<form method="post" asp-page-handler="Finish" class="inline-form">
			@foreach (var field in Model.FinishFieldsFor(soloOther)) {
				<input type="hidden" name="@field.Key" value="@field.Value"/>
			}
			<button type="submit" class="jt-icon-button" title="Finish / pause">
				<svg class="jt-icon-summary-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
					<use href="#jt-icon-finish"></use>
				</svg>
				<span class="visually-hidden">Finish / pause</span>
			</button>
		</form>
	}
	@if (Model.CanManage && !Model.IsStartClosed) {
		<partial name="_StartForTrigger" model="Model.StartFor"/>
	}
	<a class="jt-icon-button" asp-page="/Jobs/Work" asp-route-leafNodeId="@Model.LeafNodeId" title="Sessions">
		<svg class="jt-icon-summary-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
			<use href="#jt-icon-sessions"></use>
		</svg>
		<span class="visually-hidden">Sessions</span>
	</a>
</div>
