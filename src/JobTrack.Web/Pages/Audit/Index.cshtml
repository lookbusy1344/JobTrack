@page
@using JobTrack.Abstractions
@model IndexModel
@{
	ViewData["Title"] = "Audit history";
}

<div class="jt-page-head">
	<h1>Audit history</h1>
</div>

<partial name="_ErrorAlert" model="Model.ErrorMessage"/>

<form method="get" asp-page="/Audit/Index" class="jt-form-card">
	<div class="form-group">
		<label asp-for="ActorId"></label>
		<input asp-for="ActorId" class="form-control"/>
	</div>
	<div class="form-group">
		<label asp-for="EntityType"></label>
		<input asp-for="EntityType" class="form-control"/>
	</div>
	<div class="form-group">
		<label asp-for="EntityId"></label>
		<input asp-for="EntityId" class="form-control"/>
	</div>
	<div class="form-group">
		<label asp-for="CorrelationId"></label>
		<input asp-for="CorrelationId" class="form-control"/>
	</div>
	<div class="form-group">
		<label asp-for="From"></label>
		<input asp-for="From" type="datetime-local" step="60" class="form-control"/>
	</div>
	<div class="form-group">
		<label asp-for="To"></label>
		<input asp-for="To" type="datetime-local" step="60" class="form-control"/>
	</div>
	<button type="submit" class="btn btn-primary">Search</button>
</form>

@if (Model.Events.Count == 0) {
	<p class="jt-empty">No matching audit events.</p>
} else {
	<div class="jt-table-scroll">
		<table class="table">
			<thead>
			<tr>
				<th>Occurred at</th>
				<th>Actor</th>
				<th>Operation</th>
				<th>Entity type</th>
				<th>Entity id</th>
				<th>Correlation id</th>
				<th>Reason</th>
				<th>Detail</th>
			</tr>
			</thead>
			<tbody>
			@foreach (var auditEvent in Model.Events) {
				<tr>
					<td>@InstantDisplay.Format(auditEvent.OccurredAt, Model.ViewerZone)</td>
					<td class="jt-id">@(auditEvent.ActorId?.Value.ToString() ?? "system")</td>
					<td>@auditEvent.Operation</td>
					<td>@auditEvent.EntityType</td>
					<td class="jt-id">@auditEvent.EntityId</td>
					<td class="jt-id">@auditEvent.CorrelationId</td>
					<td>@auditEvent.Reason</td>
					<td>
						@if (auditEvent.IsRedacted) {
							<span>redacted</span>
						} else {
							@if (auditEvent.BeforeData is EquatableDictionary<string, string?> before) {
								<p>Before: @string.Join(", ", before.Select(field => $"{field.Key}={field.Value}"))</p>
							}

							@if (auditEvent.AfterData is EquatableDictionary<string, string?> after) {
								<p>After: @string.Join(", ", after.Select(field => $"{field.Key}={field.Value}"))</p>
							}
						}
					</td>
				</tr>
			}
			</tbody>
		</table>
	</div>

	@if (Model.NextCursor is not null) {
		<a class="btn btn-outline-secondary"
		   asp-page="/Audit/Index"
		   asp-route-ActorId="@Model.ActorId"
		   asp-route-EntityType="@Model.EntityType"
		   asp-route-EntityId="@Model.EntityId"
		   asp-route-CorrelationId="@Model.CorrelationId"
		   asp-route-From="@Model.From"
		   asp-route-To="@Model.To"
		   asp-route-Cursor="@Model.NextCursor">
			Next page
		</a>
	}
}
