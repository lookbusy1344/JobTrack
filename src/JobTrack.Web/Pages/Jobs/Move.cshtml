@page
@model MoveModel
@{
	ViewData["Title"] = "Move job node";
}

<div class="jt-page-narrow">
	<div class="jt-page-head">
		<h1>Move job node</h1>
	</div>

	<partial name="_ErrorAlert" model="Model.ErrorMessage"/>

	@if (Model.CurrentNode is not null) {
		<p class="jt-context d-flex flex-wrap align-items-baseline gap-2"><span>Moving</span><a
				class="jt-preserve-whitespace" asp-page="/Jobs/Browse"
				asp-route-nodeId="@Model.NodeId">@JobNodeDisplay.Title(Model.CurrentNode.Node)</a><span>and its subtree</span>
		</p>
		<p class="jt-context d-flex flex-wrap align-items-baseline gap-2">
			<span>Current parent</span>
			@if (Model.CurrentNode.Ancestors.Count > 0) {
				var parent = Model.CurrentNode.Ancestors[^1];
				<a class="jt-preserve-whitespace" asp-page="/Jobs/Browse" asp-route-nodeId="@parent.Id.Value">@JobNodeDisplay.Title(parent)</a>
			} else {
				<strong>none (this is the root)</strong>
			}
		</p>

		<form method="post" class="jt-form-card">
			<input type="hidden" asp-for="NodeId"/>
			<input type="hidden" asp-for="OriginalVersion"/>
			<div class="form-group">
				<label asp-for="Input.NewParentId">Destination parent's job node id</label>
				<input asp-for="Input.NewParentId" class="form-control"/>
				<span asp-validation-for="Input.NewParentId" class="text-danger"></span>
			</div>
			<div class="jt-toolbar d-flex flex-wrap gap-2 align-items-center">
				<button type="submit" class="btn btn-primary">Save</button>
				<a class="btn btn-secondary" asp-page="/Jobs/Browse" asp-route-nodeId="@Model.NodeId">Cancel</a>
			</div>
		</form>
	}
</div>
