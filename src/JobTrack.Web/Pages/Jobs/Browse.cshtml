@page
@using System.Globalization
@using JobTrack.Abstractions
@model BrowseModel
@{
	ViewData["Title"] = "Browse job";

	const int BreadcrumbMaxDescriptionLength = 50;

	// Sprite symbol id and the spoken noun for a node's kind — the two halves of the tree row's
	// leading glyph: the drawn icon (aria-hidden) and the screen-reader label that replaces it.
	static string KindIconId(NodeKind kind) => kind switch {
		NodeKind.Root => "jt-icon-root",
		NodeKind.Branch => "jt-icon-branch",
		NodeKind.Leaf => "jt-icon-leaf",
		_ => throw new ArgumentOutOfRangeException(nameof(kind), kind, null),
	};

	static string KindNoun(NodeKind kind) => kind switch {
		NodeKind.Root => "root",
		NodeKind.Branch => "branch",
		NodeKind.Leaf => "leaf",
		_ => throw new ArgumentOutOfRangeException(nameof(kind), kind, null),
	};
}

<div class="jt-page-head">
	<h1>Browse job</h1>
</div>

<partial name="_ErrorAlert" model="Model.ErrorMessage"/>

@if (Model.ErrorMessage is not null && Model.NodeId is { } missingNodeId) {
	<div hidden data-jt-missing-node-id="@missingNodeId"></div>
}

<partial name="_SuccessAlert" model="Model.SuccessMessage"/>

<div class="jt-browse-toolbar">
	@if (!Model.IsSearch && Model.CurrentNode is not null) {
		<nav aria-label="breadcrumb">
			<ol>
				@foreach (var ancestor in Model.CurrentNode.Ancestors) {
					<li>
						@if (ancestor.Kind == NodeKind.Root) {
							<a asp-page="/Jobs/Browse">@JobNodeDisplay.Title(ancestor, BreadcrumbMaxDescriptionLength)</a>
						} else {
							<a class="jt-preserve-whitespace" asp-page="/Jobs/Browse"
							   asp-route-nodeId="@ancestor.Id.Value">@JobNodeDisplay.Title(ancestor, BreadcrumbMaxDescriptionLength)</a>
						}
					</li>
				}
				<li class="jt-preserve-whitespace">@JobNodeDisplay.Title(Model.CurrentNode.Node, BreadcrumbMaxDescriptionLength)</li>
			</ol>
		</nav>
	}
</div>

@if (Model.IsSearch) {
	<h2>Search results for "@Model.SearchText"</h2>
	<partial name="_BrowseFilter" model="Model"/>
} else if (Model.CurrentNode is not null) {
	<h2 class="jt-preserve-whitespace">@JobNodeDisplay.Title(Model.CurrentNode.Node)</h2>
	<div class="row g-3 mb-4 align-items-start">
		<div class="col-md-8">
			<dl class="row mb-0">
				<dt class="col-sm-3">Kind</dt>
				<dd class="col-sm-9">
					<partial name="_KindIcon" model="@(new KindIconModel { Kind = Model.CurrentNode.Node.Kind })"/>
				</dd>
				<dt class="col-sm-3">Owner</dt>
				<dd class="col-sm-9"><span class="jt-tag">@Model.DescribeOwner(Model.CurrentNode.Node.OwnerUserId)</span></dd>
				<dt class="col-sm-3">Priority</dt>
				<dd class="col-sm-9">@EnumDisplay.Label(Model.CurrentNode.Node.Priority)</dd>
				@if (Model.Subtree?.RootTotal is { } rootTotal) {
					<dt class="col-sm-3">Cost</dt>
					<dd class="col-sm-9"><span class="jt-amount">@MoneyDisplay.Format(rootTotal)</span></dd>
				}
				@if (Model.CurrentNodeAchievement is { } currentAchievement) {
					<dt class="col-sm-3">Achievement</dt>
					<dd class="col-sm-9">
						<partial name="_AchievementIcon" model="@(new AchievementIconModel { Achievement = currentAchievement })"/>
					</dd>
				}
				@if (Model.Readiness is { } readiness) {
					<dt class="col-sm-3">Readiness</dt>
					<dd class="col-sm-9">
						@if (readiness.IsReady) {
							<span class="status-pill status-pill-ready" role="status"><svg class="status-pill-glyph" viewBox="0 0 16 16"
							                                                               aria-hidden="true" focusable="false"><use
										href="#jt-icon-go"></use></svg>Ready</span>
						} else {
							<span class="status-pill status-pill-blocked" role="status"><svg class="status-pill-glyph" viewBox="0 0 16 16"
							                                                                 aria-hidden="true" focusable="false"><use
										href="#jt-icon-stop"></use></svg>Blocked</span>
						}
					</dd>
				}
				@if (!string.IsNullOrWhiteSpace(Model.CurrentNode.Node.WriteUp)) {
					<dt class="col-sm-3">Writeup</dt>
					<dd class="col-sm-9 jt-preserve-whitespace">@Model.CurrentNode.Node.WriteUp</dd>
				}
				@if (Model.CurrentNode.Node.ArchivedAt is { } archivedAt) {
					<dt class="col-sm-3">Archived</dt>
					<dd class="col-sm-9">@InstantDisplay.Format(archivedAt, Model.ViewerZone)</dd>
				}
				@if (Model.RequestContext is { } requestContext) {
					<dt class="col-sm-3">Requester request</dt>
					<dd class="col-sm-9">
						<span class="jt-tag">@EnumDisplay.Label(requestContext.Status)</span>
						<a asp-page="/Requests/Details" asp-route-id="@requestContext.JobNodeId.Value">View request detail</a>
					</dd>
				}
			</dl>
		</div>

		<div class="col-md-4">
			<partial name="_BrowseFilter" model="Model"/>
		</div>
	</div>

	BackdateDisclosureModel? toolbarBackdate = null;
	<div class="jt-toolbar d-flex flex-wrap gap-2 align-items-center mb-4">
		@if (!Model.CurrentNode.Node.HasChildren && Model.CurrentNode.Node.Kind != NodeKind.Root) {
			var toolbarActions = Model.WorkRowActionsFor(Model.CurrentNode.Node.Id, "Start", "leafNodeId", Model.CurrentNodeAchievement, Model.CurrentNode.Node.ArchivedAt is not null, true);
			<partial name="_ActiveSincePill" model="@(new ActiveSessionSummaryModel {
				                                        ActiveSessions = toolbarActions.ActiveSessions,
				                                        ViewerId = Model.CurrentActorId ?? new AppUserId(0),
				                                        DescribeWorker = id => Model.DescribeOwner(id),
				                                        ViewerZone = Model.ViewerZone,
				                                        Now = Model.Now,
				                                        Compact = false,
				                                        StartClosed = toolbarActions.IsStartClosed,
			                                        })"/>
			@if (toolbarActions.ViewerSession is { } viewerSession) {
				<form method="post" asp-page-handler="Finish" class="inline-form">
					@foreach (var field in toolbarActions.FinishFieldsFor(viewerSession)) {
						<input type="hidden" name="@field.Key" value="@field.Value"/>
					}
					<button type="submit" class="btn btn-secondary">
						<svg class="jt-btn-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
							<use href="#jt-icon-finish"></use>
						</svg>
						Finish / pause
					</button>
				</form>
				toolbarBackdate = toolbarActions.FinishBackdateFor(viewerSession);
				<partial name="_BackdateTrigger" model="toolbarBackdate"/>
			} else if (!toolbarActions.IsStartClosed) {
				<form method="post" asp-page-handler="Start" class="inline-form">
					@foreach (var field in toolbarActions.StartFields) {
						<input type="hidden" name="@field.Key" value="@field.Value"/>
					}
					<button type="submit" class="btn btn-primary">
						<svg class="jt-btn-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
							<use href="#jt-icon-start"></use>
						</svg>
						Start session
					</button>
				</form>
				toolbarBackdate = toolbarActions.StartBackdate;
				<partial name="_BackdateTrigger" model="toolbarBackdate"/>
			}

			var soloOther = toolbarActions.SoloOtherSession;
			@if (soloOther is not null) {
				<form method="post" asp-page-handler="Finish" class="inline-form">
					@foreach (var field in toolbarActions.FinishFieldsFor(soloOther)) {
						<input type="hidden" name="@field.Key" value="@field.Value"/>
					}
					<button type="submit" class="btn btn-secondary">
						<svg class="jt-btn-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
							<use href="#jt-icon-finish"></use>
						</svg>
						Finish / pause
					</button>
				</form>
			}

			@if (toolbarActions.CanManage && !toolbarActions.IsStartClosed) {
				<partial name="_StartForTrigger" model="toolbarActions.StartFor"/>
			}

			<a class="btn btn-secondary" asp-page="/Jobs/Work" asp-route-leafNodeId="@Model.CurrentNode.Node.Id.Value">
				<svg class="jt-btn-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
					<use href="#jt-icon-sessions"></use>
				</svg>
				Sessions
			</a>
			<a class="btn btn-outline-danger"
			   asp-page="/Jobs/Delete"
			   asp-route-nodeId="@Model.CurrentNode.Node.Id.Value"
			   data-jt-confirm="Delete this job node permanently? You will review the details on the next page.">Delete</a>
			<span class="jt-toolbar-divider" aria-hidden="true"></span>
		}
		@if (Model.CurrentNode.Node.OwnerUserId is null) {
			<form method="post" asp-page-handler="PickUp" class="inline-form">
				<input type="hidden" name="NodeId" value="@Model.NodeId"/>
				<input type="hidden" name="OwnerUserId" value="@Model.OwnerUserId"/>
				<input type="hidden" name="ArchiveFilter" value="@Model.ArchiveFilter"/>
				<input type="hidden" name="SearchText" value="@Model.SearchText"/>
				<input type="hidden" name="nodeId" value="@Model.CurrentNode.Node.Id.Value"/>
				<button type="submit"
				        class='btn @(!Model.CurrentNode.Node.HasChildren && Model.CurrentNode.Node.Kind != NodeKind.Root ? "btn-secondary" : "btn-primary")'>
					Pick up
				</button>
			</form>
		}
		<a class="btn btn-secondary" asp-page="/Jobs/Edit" asp-route-nodeId="@Model.CurrentNode.Node.Id.Value">Edit</a>
		@if (Model.CurrentNode.Node.ParentId is not null) {
			<a class="btn btn-secondary" asp-page="/Jobs/Move" asp-route-nodeId="@Model.CurrentNode.Node.Id.Value">Move</a>
		}
		@if (Model.CurrentNode.Node.Kind != NodeKind.Root) {
			<a class="btn btn-secondary" asp-page="/Jobs/Prerequisites" asp-route-nodeId="@Model.CurrentNode.Node.Id.Value">Dependencies</a>
		}
		@if (Model.CurrentNode.Node.HasChildren) {
			<a class="btn btn-secondary" asp-page="/Jobs/AwaitingProgress" asp-route-subtreeRootId="@Model.CurrentNode.Node.Id.Value">Awaiting
				progress in subtree</a>
		}
		@if (!Model.CurrentNode.Node.HasChildren && Model.CurrentNode.Node.Kind != NodeKind.Root) {
			<a class="btn btn-secondary" asp-page="/Jobs/Decompose" asp-route-leafNodeId="@Model.CurrentNode.Node.Id.Value">Decompose</a>
			<a class="btn btn-secondary" asp-page="/Jobs/Achievement" asp-route-jobNodeId="@Model.CurrentNode.Node.Id.Value">Achievement</a>
		}
		@if (!Model.CurrentNode.Node.HasLeafWork) {
			<a class="btn btn-secondary" asp-page="/Jobs/Create" asp-route-parentId="@Model.CurrentNode.Node.Id.Value">Create child</a>
		}
		@if (Model.CurrentNode.Node.Kind != NodeKind.Leaf) {
			var isCurrentHomeNode = Model.HomeNodeId == Model.CurrentNode.Node.Id || (Model.HomeNodeId is null && Model.CurrentNode.Node.Kind == NodeKind.Root);
			@if (isCurrentHomeNode) {
				<form method="post" asp-page-handler="ResetHomeNode" class="inline-form">
					<input type="hidden" name="NodeId" value="@Model.NodeId"/>
					<input type="hidden" name="OwnerUserId" value="@Model.OwnerUserId"/>
					<input type="hidden" name="ArchiveFilter" value="@Model.ArchiveFilter"/>
					<input type="hidden" name="SearchText" value="@Model.SearchText"/>
					<button type="submit" class="btn btn-secondary">Reset home node to root</button>
				</form>
			} else {
				<form method="post" asp-page-handler="SetHomeNode" class="inline-form">
					<input type="hidden" name="NodeId" value="@Model.NodeId"/>
					<input type="hidden" name="OwnerUserId" value="@Model.OwnerUserId"/>
					<input type="hidden" name="ArchiveFilter" value="@Model.ArchiveFilter"/>
					<input type="hidden" name="SearchText" value="@Model.SearchText"/>
					<input type="hidden" name="nodeId" value="@Model.CurrentNode.Node.Id.Value"/>
					<button type="submit" class="btn btn-secondary">Set as home node</button>
				</form>
			}
		}
	</div>
	@if (toolbarBackdate is not null) {
		@if (toolbarBackdate is not null) {
			<partial name="_BackdatePanel" model="toolbarBackdate"/>
		}
	}

	@if (Model.LeafWorkSessions is { } leafWorkSessions) {
		<partial name="_LeafWorkSessions" model="leafWorkSessions"/>
	}

	@if (Model.CurrentNode.Node.Kind != NodeKind.Root) {
		@* Requires and Depends-on always appear together, so they share one card (ADR 0044 browse
		   layout): a single full-width surface flush with the toolbar and subtree. The two lists sit
		   side by side on wide screens and stack on narrow ones, each under its own directional
		   heading. Always shown — not a disclosure. *@
		<div class="jt-card mb-4">
			<div class="d-flex flex-column flex-md-row gap-4">
				<div class="flex-fill">
					<p class="jt-list-heading">&larr; Requires (must finish first)</p>
					@if (Model.Requires.Count == 0) {
						<p class="jt-empty">None.</p>
					} else {
						<ul class="jt-list jt-list--wide mb-0">
							@foreach (var node in Model.Requires) {
								<li class="d-flex flex-wrap align-items-center gap-3">
									@if (Model.BlockingRequiredIds.Contains(node.Id)) {
										<span class="status-pill status-pill--icon status-pill-blocked" role="status"><svg class="status-pill-glyph"
										                                                                                   viewBox="0 0 16 16"
										                                                                                   aria-hidden="true"
										                                                                                   focusable="false"><use
													href="#jt-icon-stop"></use></svg><span class="visually-hidden">Blocking</span></span>
									} else {
										<span class="status-pill status-pill--icon status-pill-ready" role="status"><svg class="status-pill-glyph"
										                                                                                 viewBox="0 0 16 16"
										                                                                                 aria-hidden="true"
										                                                                                 focusable="false"><use
													href="#jt-icon-go"></use></svg><span class="visually-hidden">Satisfied</span></span>
									}
									<a class="jt-preserve-whitespace" asp-page="/Jobs/Browse"
									   asp-route-nodeId="@node.Id.Value">@JobNodeDisplay.Title(node)</a>
									<span class="d-flex align-items-center gap-2 ms-auto">
										<partial name="_KindIcon" model="@(new KindIconModel { Kind = node.Kind, CollapseLabelOnNarrow = true })"/>
										@if (node.ArchivedAt is not null) {
											<span class="jt-muted"> · archived</span>
										}
									</span>
								</li>
							}
						</ul>
					}
				</div>
				<div class="flex-fill">
					@* Nudged right to sit level with where "Requires" begins after its leading arrow. *@
					<p class="jt-list-heading ps-3">Depends on this job &rarr;</p>
					@if (Model.RequiredBy.Count == 0) {
						<p class="jt-empty">None.</p>
					} else {
						<ul class="jt-list jt-list--wide mb-0">
							@foreach (var node in Model.RequiredBy) {
								<li class="d-flex flex-wrap align-items-center gap-3">
									<a class="jt-preserve-whitespace" asp-page="/Jobs/Browse"
									   asp-route-nodeId="@node.Id.Value">@JobNodeDisplay.Title(node)</a>
									<span class="d-flex align-items-center gap-2 ms-auto">
										<partial name="_KindIcon" model="@(new KindIconModel { Kind = node.Kind, CollapseLabelOnNarrow = true })"/>
										@if (node.ArchivedAt is not null) {
											<span class="jt-muted"> · archived</span>
										}
									</span>
								</li>
							}
						</ul>
					}
				</div>
			</div>
		</div>

		@if (Model.AncestorBlockers.Count > 0) {
			<details class="jt-card">
				<summary class="jt-disclosure-summary">Inherited blockers (from ancestor prerequisites)</summary>
				<ul class="jt-list jt-list--wide mb-0">
					@foreach (var blocker in Model.AncestorBlockers) {
						<li class="d-flex flex-wrap align-items-center justify-content-between gap-3">
							<span class="status-pill status-pill--icon status-pill-blocked" role="status"><svg class="status-pill-glyph"
							                                                                                   viewBox="0 0 16 16" aria-hidden="true"
							                                                                                   focusable="false"><use
										href="#jt-icon-stop"></use></svg><span class="visually-hidden">Blocking</span></span>
							<a class="jt-preserve-whitespace" asp-page="/Jobs/Browse"
							   asp-route-nodeId="@blocker.RequiredJobId">@JobNodeDisplay.Title(blocker.RequiredDescription, blocker.RequiredJobId)</a>
							<span class="jt-muted">declared on</span>
							<a class="jt-preserve-whitespace" asp-page="/Jobs/Browse"
							   asp-route-nodeId="@blocker.DeclaredOnJobId">@JobNodeDisplay.Title(blocker.DeclaredOnDescription, blocker.DeclaredOnJobId)</a>
						</li>
					}
				</ul>
			</details>
		}
	}
}

@if (Model.IsSearch) {
	<h2>Matches</h2>
	@if (Model.Children.Count == 0) {
		<p class="jt-empty">No jobs to show.</p>
	} else {
		<div class="jt-table-scroll">
			<table class="table">
				<thead>
				<tr>
					<th scope="col">Description</th>
					<th scope="col">Kind</th>
					<th scope="col" class="jt-col-secondary jt-col-owner">Owner</th>
					<th scope="col" class="jt-col-active">Active</th>
					<th scope="col" class="jt-col-cost text-end">Cost</th>
					<th scope="col" class="jt-col-secondary">Archived</th>
					<th scope="col" class="text-end">Actions</th>
				</tr>
				</thead>
				<tbody>
				@foreach (var child in Model.Children) {
					var childActions = child.HasChildren
						? null
						: Model.WorkRowActionsFor(child.Id, "Start", "leafNodeId", child.Achievement, child.ArchivedAt is not null);
					<tr>
						<td>
							<a class="jt-preserve-whitespace" asp-page="/Jobs/Browse"
							   asp-route-nodeId="@child.Id.Value">@JobNodeDisplay.Title(child)</a>
							<partial name="_AchievementIcon"
							         model="@(new AchievementIconModel { Achievement = child.Achievement, ShowLabel = false })"/>
							@if (child.HasChildren) {
								<span class="jt-muted"> · has children</span>
							}
						</td>
						<td>
							<partial name="_KindIcon" model="@(new KindIconModel { Kind = child.Kind, ShowLabel = false })"/>
						</td>
						<td class="jt-col-secondary jt-col-owner">
							@if (child.OwnerUserId is { } childOwnerUserId) {
								@Model.DescribeOwner(childOwnerUserId)
							} else {
								<span>Unassigned</span>
								<form method="post" asp-page-handler="PickUp" class="inline-form">
									<input type="hidden" name="NodeId" value="@Model.NodeId"/>
									<input type="hidden" name="OwnerUserId" value="@Model.OwnerUserId"/>
									<input type="hidden" name="ArchiveFilter" value="@Model.ArchiveFilter"/>
									<input type="hidden" name="SearchText" value="@Model.SearchText"/>
									<input type="hidden" name="nodeId" value="@child.Id.Value"/>
									<button type="submit" class="btn btn-secondary">Pick up</button>
								</form>
							}
						</td>
						<td class="jt-col-active">
							<partial name="_ActiveSincePill"
							         model="@(new ActiveSessionSummaryModel {
								                ActiveSessions = childActions?.ActiveSessions ?? [],
								                ViewerId = Model.CurrentActorId ?? new AppUserId(0),
								                DescribeWorker = id => Model.DescribeOwner(id),
								                ViewerZone = Model.ViewerZone,
								                Now = Model.Now,
								                StartClosed = childActions?.IsStartClosed ?? false,
							                })"/>
						</td>
						<td class="jt-col-cost text-end">
							@if (child.Cost is { } cost) {
								@MoneyDisplay.Format(cost)
							}
						</td>
						<td class="jt-col-secondary">@(child.ArchivedAt is not null ? "yes" : "no")</td>
						<td>
							@if (childActions is not null) {
								<partial name="_WorkRowActions" model="childActions"/>
							}
						</td>
					</tr>
					@if (childActions is not null) {
						<partial name="_BackdateRow"
						         model="@(new BackdateRowModel { Disclosure = childActions.ViewerSession is { } childViewerSession ? childActions.FinishBackdateFor(childViewerSession) : childActions.StartBackdate, ColumnCount = 7 })"/>
					}
				}
				</tbody>
			</table>
		</div>
	}
} else if (Model.Subtree is not null) {
	<h2>Subtree</h2>

	@if (Model.SubtreeDescendants.Count == 0) {
		@if (Model.CurrentNode is { Node.HasChildren: false, Node.HasLeafWork: true }) {
			<p class="jt-empty">This node has no children. Use Work or Decompose above to record progress.</p>
		} else if (Model.CurrentNode is { Node.HasChildren: false }) {
			<p class="jt-empty">This node has no children. Use Work or Decompose above to record progress, or create a child.</p>
		} else {
			<p class="jt-empty">No jobs to show.</p>
		}
	} else {
		<div class="jt-table-scroll">
			<table class="table">
				<thead>
				<tr>
					@* No Kind or Archived column: the row's leading glyph names root/branch/leaf, and an
					   archived row is flagged in place beside its name. *@
					<th scope="col">Description</th>
					<th scope="col" class="jt-col-secondary jt-col-owner">Owner</th>
					<th scope="col" class="jt-col-active">Active</th>
					<th scope="col" class="jt-col-cost text-end">Cost</th>
					@* The heading is visually hidden, not removed: the word "Position" is nearly five times
					   the width of the bar it labels, so with it visible the column can never narrow to
					   the bar's own size however small the bar gets. Assistive tech still gets the name. *@
					<th scope="col" class="jt-col-secondary jt-col-span"><span class="visually-hidden">Position</span></th>
					<th scope="col" class="text-end">Actions</th>
				</tr>
				</thead>
				<tbody>
				@foreach (var node in Model.SubtreeDescendants) {
					var (leftPct, widthPct) = Model.SubtreeSpanPercent(node);
					var nodeActions = node.HasChildren
						? null
						: Model.WorkRowActionsFor(node.Id, "Start", "leafNodeId", node.Achievement, node.ArchivedAt is not null);
					<tr>
						<td class="jt-tree-cell" data-jt-depth="@node.Depth">
							<span class="jt-tree-guide" aria-hidden="true">
								@for (var railLevel = 1; railLevel < node.Depth; railLevel++) {
									<span class="jt-tree-rail"></span>
								}
								<span class="jt-tree-elbow"></span>
							</span>
							<span class="jt-tree-label">
								@if (!node.IsReady) {
									@* ADR 0043 decision 2: blocked rows are marked and ready rows are not — in a
									   healthy tree a sign on every row would bury the few that matter. The same
									   stop palm the readiness pill uses, so the two never read as different facts.
									   Leads the row (beside the kind icon, ahead of the name) so it reads at a
									   glance rather than after scanning past the name first. *@
									<svg class="jt-tree-flag jt-tree-blocked jt-tree-flag--leading" viewBox="0 0 16 16" aria-hidden="true"
									     focusable="false">
										<use href="#jt-icon-stop"></use>
									</svg>
									<span class="visually-hidden">Blocked by a prerequisite.</span>
								}
								<svg class="jt-tree-icon jt-tree-icon--@KindNoun(node.Kind)" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
									<use href="#@KindIconId(node.Kind)"></use>
								</svg>
								<span class="jt-tree-text">
									<span class="visually-hidden">Level @node.Depth, @KindNoun(node.Kind).</span>
									<a class="jt-tree-name-link jt-preserve-whitespace" asp-page="/Jobs/Browse"
									   asp-route-nodeId="@node.Id.Value">@node.Description</a>
									@* Trails the name rather than leading it: unlike the blocked palm, an achievement
									   is present on most leaves in a healthy tree, so it belongs where the eye lands
									   after reading the row, not competing with the kind glyph for the leading slot. *@
									<partial name="_AchievementIcon"
									         model="@(new AchievementIconModel { Achievement = node.Achievement, ShowLabel = false })"/>
									@if (node.HasUnexpandedChildren) {
										@* The name already links here; this only says the container holds more
										   than is drawn, so it is a marker, not a second link to the same page. *@
										<span class="jt-tree-more" aria-hidden="true">&hellip;</span>
										<span class="visually-hidden">More levels below.</span>
									}
									@if (node.ArchivedAt is not null) {
										@* Replaces the Archived column: archived rows are the exception, so the
										   fact belongs on the few rows that carry it, not in a column of "no". *@
										<svg class="jt-tree-flag" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
											<use href="#jt-icon-archived"></use>
										</svg>
										<span class="visually-hidden">Archived.</span>
									}
								</span>
							</span>
						</td>
						<td class="jt-col-secondary jt-col-owner">
							@if (node.OwnerUserId is { } nodeOwnerUserId) {
								@Model.DescribeOwner(nodeOwnerUserId)
							} else {
								<span>Unassigned</span>
								<form method="post" asp-page-handler="PickUp" class="inline-form">
									<input type="hidden" name="NodeId" value="@Model.NodeId"/>
									<input type="hidden" name="OwnerUserId" value="@Model.OwnerUserId"/>
									<input type="hidden" name="ArchiveFilter" value="@Model.ArchiveFilter"/>
									<input type="hidden" name="SearchText" value="@Model.SearchText"/>
									<input type="hidden" name="nodeId" value="@node.Id.Value"/>
									<button type="submit" class="btn btn-secondary">Pick up</button>
								</form>
							}
						</td>
						<td class="jt-col-active">
							<partial name="_ActiveSincePill"
							         model="@(new ActiveSessionSummaryModel {
								                ActiveSessions = nodeActions?.ActiveSessions ?? [],
								                ViewerId = Model.CurrentActorId ?? new AppUserId(0),
								                DescribeWorker = id => Model.DescribeOwner(id),
								                ViewerZone = Model.ViewerZone,
								                Now = Model.Now,
								                StartClosed = nodeActions?.IsStartClosed ?? false,
							                })"/>
						</td>
						<td class="jt-col-cost text-end">
							@if (node.Cost is { } cost) {
								@MoneyDisplay.Format(cost)
							}
						</td>
						<td class="jt-col-secondary jt-col-span">
							@* Geometry as SVG presentation attributes, not a `style` attribute: the CSP is
							   `style-src 'self'` with no `'unsafe-inline'`, so an inline style is dropped
							   and the bar silently collapses to nothing. The viewBox is 100 wide, so the
							   percentages map straight onto user units. *@
							<span class="jt-tree-span-track" aria-hidden="true">
								<svg class="jt-tree-span" viewBox="0 0 100 6" preserveAspectRatio="none" focusable="false">
									<rect class="jt-tree-span-fill" y="0" height="6"
									      x="@leftPct.ToString("0.##", CultureInfo.InvariantCulture)"
									      width="@widthPct.ToString("0.##", CultureInfo.InvariantCulture)"/>
								</svg>
							</span>
						</td>
						<td>
							@if (nodeActions is not null) {
								<partial name="_WorkRowActions" model="nodeActions"/>
							}
						</td>
					</tr>
					@if (nodeActions is not null) {
						<partial name="_BackdateRow"
						         model="@(new BackdateRowModel { Disclosure = nodeActions.ViewerSession is { } nodeViewerSession ? nodeActions.FinishBackdateFor(nodeViewerSession) : nodeActions.StartBackdate, ColumnCount = 6 })"/>
					}
				}
				</tbody>
			</table>
		</div>
	}
}

@if (Model.CurrentNode is not null && !Model.IsSearch) {
	<aside class="jt-history" id="jt-history" aria-label="Recently visited">
		<p class="jt-history-label">Recently visited</p>
		<ul id="jt-history-list" class="jt-history-list"></ul>
	</aside>
	<div hidden
	     data-jt-node-id="@Model.CurrentNode.Node.Id.Value"
	     data-jt-node-description="@Model.CurrentNode.Node.Description"
	     data-jt-node-kind="@Model.CurrentNode.Node.Kind"></div>
}

@section Scripts {
	<script src="~/js/job-history.js" asp-append-version="true"></script>
}
