@page
@using System.Globalization
@model CostReportModel
@{
	ViewData["Title"] = "Cost report";
}

<div class="jt-page-head">
	<h1>Cost report</h1>
</div>

<partial name="_ErrorAlert" model="Model.ErrorMessage"/>

<form method="get" asp-page="/Jobs/CostReport" class="jt-form-card">
	<div class="form-group">
		<label asp-for="NodeId"></label>
		<input asp-for="NodeId" class="form-control"/>
	</div>
	<div class="form-group">
		<label asp-for="AsOf">As of (leave blank for now)</label>
		<input asp-for="AsOf" type="datetime-local" step="60" class="form-control"/>
	</div>
	<button type="submit" class="btn btn-primary">View</button>
</form>

@if (Model.Node is not null) {
	<h2><a class="jt-preserve-whitespace" asp-page="/Jobs/Browse" asp-route-nodeId="@Model.NodeId">@JobNodeDisplay.Title(Model.Node.Node)</a></h2>

	<p><a asp-page="/Jobs/Browse" asp-route-nodeId="@Model.NodeId">&larr; Back to Browse</a></p>

	@if (Model.Readiness is not null) {
		<partial name="_Readiness" model="Model.Readiness"/>
	}

	var costDetails = Model.CostDetails;
	@if (costDetails is not null) {
		<div class="row row-cols-1 row-cols-sm-2 g-3 mb-4">
			<div class="col jt-metric">
				<span class="jt-metric-label">Exact cost</span>
				<span class="jt-metric-value jt-amount">@MoneyDisplay.Format(costDetails.ExactCost)</span>
			</div>
			<div class="col jt-metric">
				<span class="jt-metric-label">Displayed cost</span>
				<span class="jt-metric-value jt-amount">@MoneyDisplay.Format(costDetails.DisplayedCost)</span>
				<span class="jt-metric-sub">Rounded to pennies</span>
			</div>
		</div>

		<h3>Rate provenance</h3>
		@if (costDetails.Trace.Count == 0) {
			<p class="jt-empty">No costed segments.</p>
		} else {
			<div class="jt-table-scroll">
				<table class="table">
					<thead>
					<tr>
						<th>Segment start</th>
						<th>Segment end</th>
						<th>Rate per hour</th>
						<th>Rate source</th>
						<th>Contribution</th>
					</tr>
					</thead>
					<tbody>
					@foreach (var entry in costDetails.Trace) {
						<tr>
							<td>@InstantDisplay.Format(entry.Segment.Start, Model.ViewerZone)</td>
							<td>@InstantDisplay.Format(entry.Segment.End, Model.ViewerZone)</td>
							<td class="jt-amount">@entry.ResolvedRate.Rate.AmountPerHour.ToString("0.00", CultureInfo.InvariantCulture)</td>
							<td>@entry.ResolvedRate.Source</td>
							<td class="jt-amount">@MoneyDisplay.Format(entry.UnroundedContribution)</td>
						</tr>
					}
					</tbody>
				</table>
			</div>
		}
	}
}
