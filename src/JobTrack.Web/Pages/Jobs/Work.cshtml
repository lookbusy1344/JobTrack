@page
@using JobTrack.Abstractions
@model WorkModel
@{
	ViewData["Title"] = Model.WorkPage?.Description ?? "Work";
	var workPage = Model.WorkPage;
	var isTerminal = workPage?.Achievement is Achievement.Success or Achievement.Cancelled or Achievement.Unsuccessful;
	var isArchived = workPage?.ArchivedAt is not null;
	// In Progress with nobody clocked on: paused, not broken (ADR 0045). Named here, and it still gets
	// the ending decision -- completing from zero sessions is the supported path, not a special case.
	var isPaused = LeafActivity.IsPaused(workPage?.Achievement, workPage?.ActiveSessions.Count ?? 0);
	// The one section that carries the write-up inside its own form (with Pause job / Complete job);
	// every other state renders it standalone below, so it never appears twice.
	var hasEndingSection = workPage is not null && !isArchived && !isTerminal
	                       && (workPage.ActiveSessions.Count > 0 || (isPaused && workPage.CanComplete));
}

<div class="jt-page-head">
	<h1>Work sessions</h1>
	@if (workPage is not null && Model.CurrentNode is not null) {
		<h2 class="jt-preserve-whitespace"><a asp-page="/Jobs/Browse" asp-route-nodeId="@Model.LeafNodeId">@JobNodeDisplay.Title(Model.CurrentNode.Node)</a></h2>
	}
</div>

<partial name="_ErrorAlert" model="Model.ErrorMessage"/>

<partial name="_SuccessAlert" model="Model.SuccessMessage"/>

@if (workPage is not null) {
	<div class="jt-card mb-4" id="status">
		<div class="d-flex flex-wrap align-items-center gap-2 mb-3">
			<partial name="_AchievementIcon" model="@(new AchievementIconModel { Achievement = workPage.Achievement })"/>
			@if (workPage.HasLeafWork && workPage.Achievement == Achievement.Waiting && workPage.ActiveSessions.Count == 0) {
				@if (workPage.IsReady) {
					<span class="status-pill status-pill-ready" role="status">
						<svg class="status-pill-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false"><use href="#jt-icon-go"></use></svg>
						No blocks
					</span>
				} else {
					<span class="status-pill status-pill-blocked" role="status">
						<svg class="status-pill-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false"><use href="#jt-icon-stop"></use></svg>
						Blocked
					</span>
				}
			}
			@if (isTerminal && workPage.ActiveSessions.Count == 0) {
				<span class="status-pill status-pill-closed">Closed</span>
			}
			@if (isPaused && !isArchived) {
				<partial name="_PausedPill"/>
			}
			@if (isArchived) {
				<span class="status-pill status-pill-closed">Archived</span>
			}
		</div>

		@if (isArchived) {
			<div class="jt-notice">
				<p>
					This job is archived, so no new session can start here regardless of achievement.
					An administrator must restore it first@(isTerminal ? ", then it can be reopened and a new session started." : ".")
				</p>
			</div>
		} else if (isTerminal) {
			@if (workPage.Achievement == Achievement.Success) {
				<p>Completed. To record more work, reopen this job and start a new session.</p>
			} else if (workPage.Achievement == Achievement.Cancelled) {
				<p>Cancelled. To record more work, reopen this job and start a new session.</p>
			} else if (workPage.Achievement == Achievement.Unsuccessful) {
				<p>Unsuccessful. To record more work, reopen this job and start a new session.</p>
			}

			@if (workPage.DirectDependentCount > 0 && workPage.Achievement == Achievement.Success) {
				<div class="jt-notice">
					<p>
						@workPage.DirectDependentCount job@(workPage.DirectDependentCount == 1 ? "" : "s") currently
						depend@(workPage.DirectDependentCount == 1 ? "s" : "")
						on this leaf's success. Reopening it will
						make @(workPage.DirectDependentCount == 1 ? "that dependent" : "those dependents") blocked again.
					</p>
				</div>
			}

			@if (workPage.CanReopenAndStartForSelf || workPage.CanReopenAndStartForOthers) {
				<form method="post" asp-page-handler="ReopenAndStart" class="jt-form-card" id="end-session">
					<input type="hidden" name="LeafNodeId" value="@Model.LeafNodeId"/>
					<input type="hidden" name="leafWorkVersion" value="@workPage.LeafWorkVersion"/>
					<h2 class="h5">Reopen and start session</h2>
					<div class="form-group">
						<label for="reopenReason">Reason</label>
						<input list="reopenReasonChoices" id="reopenReason" name="reason" class="form-control" required/>
						<datalist id="reopenReasonChoices">
							<option value="Closed by mistake"></option>
							<option value="More work was found"></option>
							<option value="Work resumed"></option>
						</datalist>
					</div>
					@* Named reopenWorkedByUserId, not workedByUserId -- model binding is case-insensitive, so
					   the plain name would double-bind onto this page's own WorkedByUserId sessions-filter
					   property (same pattern as Browse's PickUpAsync/pickUpNodeId) and the redirect below
					   would then carry it as an explicit query value, silently pinning the Sessions filter
					   to whoever was just reopened for -- usually the actor themselves. *@
					@if (workPage.CanReopenAndStartForOthers) {
						<div class="form-group">
							<label for="reopenWorkedByUserId">Worker</label>
							<select id="reopenWorkedByUserId" name="reopenWorkedByUserId" class="form-control"
							        asp-items="Model.ReopenWorkerOptions"></select>
						</div>
					} else {
						<input type="hidden" name="reopenWorkedByUserId" value="@Model.CurrentActorId?.Value"/>
					}
					<div class="form-group">
						<label for="reopenStartedAt">Started at (optional backdate)</label>
						<input type="datetime-local" id="reopenStartedAt" name="startedAt" class="form-control"/>
					</div>
					<button type="submit" class="btn btn-primary">Reopen and start session</button>
				</form>
			} else {
				<p class="jt-muted">
					A prior participant on this leaf, the controlling owner, a Job Manager, or an Administrator can reopen it.
				</p>
			}
		} else {
			@if (workPage.ActiveSessions.Count > 0) {
				<div class="mb-3">
					<partial name="_ActiveSincePill" model="@(new ActiveSessionSummaryModel {
						                                        ActiveSessions = workPage.ActiveSessions,
						                                        ViewerId = Model.CurrentActorId ?? new AppUserId(0),
						                                        DescribeWorker = Model.DescribeWorker,
						                                        ViewerZone = Model.ViewerZone,
						                                        Now = Model.Now,
						                                        Compact = false,
					                                        })"/>
				</div>
			} else {
				var toolbarActions = Model.ToolbarActions;
				@if (workPage.CanManageSessions) {
					<div class="jt-toolbar d-flex flex-wrap gap-2 align-items-center mb-3">
						<form method="post" asp-page-handler="Start" class="inline-form">
							@foreach (var field in Model.ToolbarStateFields) {
								<input type="hidden" name="@field.Key" value="@field.Value"/>
							}
							<button type="submit" class="btn btn-primary">
								<svg class="jt-btn-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
									<use href="#jt-icon-start"></use>
								</svg>
								Start session
							</button>
						</form>
						<partial name="_BackdateTrigger" model="toolbarActions.StartBackdate"/>
						<partial name="_StartForTrigger" model="toolbarActions.StartFor"/>
						<a class="btn btn-secondary" asp-page="/Jobs/Browse" asp-route-nodeId="@Model.LeafNodeId">Browse</a>
					</div>
					<partial name="_BackdatePanel" model="toolbarActions.StartBackdate"/>
				} else {
					<p class="jt-muted">A controlling owner, Job Manager, or Administrator can start work on this job.</p>
				}
			}

			var presentation = ActiveSessionPresentation.Derive(workPage.ActiveSessions, Model.CurrentActorId ?? new AppUserId(0));

			var pausable = presentation.ViewerSession
			               ?? (workPage.CanManageSessions && presentation.Count == 1 ? presentation.OtherSessions[0] : null);

			@* The same ending decision whether sessions are running or the leaf is merely paused --
			   completing from zero sessions is the supported path (ADR 0045), so a paused leaf gets
			   this card rather than a second, differently-worded "Mark complete" affordance.

			   One form, three buttons: Pause job, Complete job and Save write-up all post the same
			   fields to their own handler (asp-page-handler on the button becomes formaction), so
			   whichever the worker presses carries the write-up they just typed. The Pause pair
			   (sessionId/version) and the Complete arrays (completeSessionId/completeSessionVersion)
			   coexist here, which is why the latter carry a prefix. *@
			if (hasEndingSection) {
				<form method="post" asp-page-handler="Complete" id="end-session">
					<input type="hidden" name="LeafNodeId" value="@Model.LeafNodeId"/>
					<input type="hidden" name="leafWorkVersion" value="@workPage.LeafWorkVersion"/>
					@if (pausable is not null) {
						<input type="hidden" name="sessionId" value="@pausable.Id.Value"/>
						<input type="hidden" name="version" value="@pausable.Version"/>
					}
					@if (workPage.CanComplete) {
						foreach (var session in presentation.StableOrder) {
							<input type="hidden" name="completeSessionId" value="@session.Id.Value"/>
							<input type="hidden" name="completeSessionVersion" value="@session.Version"/>
						}
					}
					@if (Model.CurrentNode is not null) {
						<partial name="_WriteUpField"
						         model="@(new WriteUpFieldModel { NodeVersion = Model.CurrentNode.Node.Version, WriteUp = Model.CurrentNode.Node.WriteUp })"/>
					}
					@if (workPage.CanComplete) {
						<div class="jt-completion-review mt-3">
							<details>
								<summary>Completion options</summary>
								<div class="form-group mt-2">
									<label for="completionAchievement">Outcome</label>
									<select id="completionAchievement" name="finalAchievement" class="form-control"
									        asp-items="Model.CompletionAchievementOptions"></select>
								</div>
								<div class="form-group">
									<label for="completionFinishedAt">Finished at (optional backdate)</label>
									<input type="datetime-local" id="completionFinishedAt" name="completionFinishedAt" class="form-control"/>
								</div>
								<div class="form-group">
									<label for="completionNote">Completion note (optional)</label>
									<input id="completionNote" name="completionNote" class="form-control"/>
								</div>
							</details>
						</div>
					}
					<div class="jt-toolbar d-flex flex-wrap gap-2 align-items-center mt-3">
						@if (pausable is not null) {
							<button type="submit" asp-page-handler="Finish" class="btn btn-secondary"
							        title="Ends this session; the job stays In Progress.">
								<svg class="jt-btn-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
									<use href="#jt-icon-finish"></use>
								</svg>
								Pause job
							</button>
						}
						@if (workPage.CanComplete) {
							<button type="submit" class="btn btn-primary">
								<svg class="jt-btn-glyph" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
									<use href="#jt-icon-go"></use>
								</svg>
								@(workPage.ActiveSessions.Count <= 1
									? "Complete job"
									: $"Finish {workPage.ActiveSessions.Count} sessions and complete job")
							</button>
						} else if (pausable is null) {
							<p class="jt-muted">A controlling owner, Job Manager, or Administrator can end this job here.</p>
						}
						@if (Model.CurrentNode is not null) {
							<button type="submit" asp-page-handler="SaveWriteUp" class="btn btn-secondary"
							        title="Saves the write-up only; the job's status is unchanged.">
								Save write-up
							</button>
						}
					</div>
				</form>
			}
		}

		@* Every state that has no ending section still gets the write-up, in the same card and with
		   the same field -- just its own Save button rather than sharing one form with Pause and
		   Complete. *@
		@if (Model.CurrentNode is not null && !hasEndingSection) {
			<form method="post" asp-page-handler="SaveWriteUp" class="mt-3" id="writeup">
				<input type="hidden" name="LeafNodeId" value="@Model.LeafNodeId"/>
				<partial name="_WriteUpField"
				         model="@(new WriteUpFieldModel { NodeVersion = Model.CurrentNode.Node.Version, WriteUp = Model.CurrentNode.Node.WriteUp })"/>
				<button type="submit" class="btn btn-secondary">Save write-up</button>
			</form>
		}
	</div>

	@if (Model.ChangeOutcomeOptions.Count > 0 && !isArchived) {
		<details class="jt-card mb-4">
			<summary>Change outcome</summary>
			<form method="post" asp-page-handler="SetAchievement" class="jt-form-card mt-3">
				<input type="hidden" name="LeafNodeId" value="@Model.LeafNodeId"/>
				<input type="hidden" name="leafWorkVersion" value="@workPage.LeafWorkVersion"/>
				<div class="form-group">
					<label for="changeOutcomeAchievement">New status</label>
					<select id="changeOutcomeAchievement" name="newAchievement" class="form-control"
					        asp-items="Model.ChangeOutcomeOptions"></select>
				</div>
				<div class="form-group">
					<label for="changeOutcomeReason">Reason</label>
					<input id="changeOutcomeReason" name="reason" class="form-control" required/>
				</div>
				<p class="jt-muted">Reopening a closed job (to Waiting) requires Job Manager or Administrator authority, regardless of subtree
					ownership.</p>
				<button type="submit" class="btn btn-secondary">Save</button>
			</form>
		</details>
	}

	@if (Model.Panel is not null) {
		<partial name="_LeafWorkSessions" model="Model.Panel"/>
	}
}
