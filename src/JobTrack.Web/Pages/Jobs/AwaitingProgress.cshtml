@page
@using JobTrack.Abstractions
@model AwaitingProgressModel
@{
	ViewData["Title"] = "Jobs awaiting progress";
}

<div class="jt-page-head">
	<p class="jt-eyebrow">Dashboard</p>
	<h1>Jobs awaiting progress</h1>
</div>

<partial name="_ErrorAlert" model="Model.ErrorMessage"/>

<partial name="_SuccessAlert" model="Model.SuccessMessage"/>

@if (Model.SubtreeRoot is { } subtreeRoot) {
	<p class="jt-context d-flex flex-wrap align-items-baseline gap-2">
		<span>Scoped to <strong><a class="jt-preserve-whitespace" asp-page="/Jobs/Browse"
		                           asp-route-nodeId="@subtreeRoot.Node.Id.Value">@JobNodeDisplay.Title(subtreeRoot.Node)</a></strong></span>
		<a asp-page="/Jobs/AwaitingProgress" asp-route-ownerUserId="@Model.OwnerUserId">Show the whole tree</a>
	</p>
}

<form method="get" asp-page="/Jobs/AwaitingProgress" class="jt-form-card">
	<input type="hidden" asp-for="SubtreeRootId"/>
	<div class="form-group">
		<label asp-for="OwnerUserId">Owner</label>
		<select asp-for="OwnerUserId" class="form-control" asp-items="Model.OwnerOptions"></select>
	</div>
	<div class="form-group">
		<label asp-for="UnassignedOnly">
			<input asp-for="UnassignedOnly"/>
			Unassigned only (the pickup pool)
		</label>
	</div>
	<button type="submit" class="btn btn-primary">Apply</button>
	<a class="btn btn-secondary" asp-page="/Jobs/Browse" asp-route-nodeId="@Model.SubtreeRootId">Browse</a>
</form>

@if (Model.Entries.Count == 0) {
	<p class="jt-empty">No jobs are awaiting progress.</p>
} else {
	<div class="jt-table-scroll">
		<table class="table">
			<thead>
			<tr>
				<th>Description</th>
				<th class="jt-col-secondary jt-col-owner">Owner</th>
				<th class="jt-col-active">Active</th>
				<th class="jt-col-cost text-end">Cost</th>
				<th class="jt-col-cost">Achievement</th>
				<th class="jt-col-secondary">Deadline</th>
				<th class="text-end">Actions</th>
			</tr>
			</thead>
			<tbody>
			@foreach (var entry in Model.Entries) {
				var entryActions = Model.WorkRowActionsFor(entry.Id, entry.Achievement);
				<tr>
					<td>
						@if (!entry.IsReady) {
							<span class="status-pill status-pill--icon status-pill-blocked"><svg class="status-pill-glyph" viewBox="0 0 16 16"
							                                                                     aria-hidden="true" focusable="false"><use
										href="#jt-icon-stop"></use></svg><span class="visually-hidden">Blocked</span></span>
						}
						<a class="jt-preserve-whitespace" asp-page="/Jobs/Browse" asp-route-nodeId="@entry.Id.Value">@JobNodeDisplay.Title(entry)</a>
					</td>
					<td class="jt-col-secondary jt-col-owner">@Model.DescribeOwner(entry.OwnerUserId)</td>
					<td class="jt-col-active">
						<partial name="_ActiveSincePill"
						         model="@(new ActiveSessionSummaryModel {
							                ActiveSessions = entryActions.ActiveSessions,
							                ViewerId = Model.CurrentActorId ?? new AppUserId(0),
							                DescribeWorker = id => Model.DescribeOwner(id),
							                ViewerZone = Model.ViewerZone,
							                Now = Model.Now,
							                StartClosed = entryActions.IsStartClosed,
						                })"/>
					</td>
					<td class="jt-col-cost text-end">@(entry.Cost is { } cost ? MoneyDisplay.Format(cost) : null)</td>
					<td class="jt-col-cost">
						@if (entry.Achievement is { } achievement) {
							<partial name="_AchievementIcon" model="@(new AchievementIconModel { Achievement = achievement })"/>
						} else {
							<span class="jt-muted">None</span>
						}
					</td>
					<td class="jt-col-secondary">@((entry.NeededFinish ?? entry.NeededStart) is { } needed ? InstantDisplay.Format(needed, Model.ViewerZone) : null)</td>
					<td>
						<partial name="_WorkRowActions" model="entryActions"/>
					</td>
				</tr>
				<partial name="_BackdateRow"
				         model="@(new BackdateRowModel { Disclosure = entryActions.ViewerSession is { } entryViewerSession ? entryActions.FinishBackdateFor(entryViewerSession) : entryActions.StartBackdate, ColumnCount = 7 })"/>
			}
			</tbody>
		</table>
	</div>

	@if (Model.HasMore) {
		<a class="btn btn-outline-secondary"
		   asp-page="/Jobs/AwaitingProgress"
		   asp-route-OwnerUserId="@Model.OwnerUserId"
		   asp-route-UnassignedOnly="@Model.UnassignedOnly"
		   asp-route-SubtreeRootId="@Model.SubtreeRootId"
		   asp-route-Offset="@(Model.Offset + AwaitingProgressModel.PageSize)">
			Next page
		</a>
	}
}
