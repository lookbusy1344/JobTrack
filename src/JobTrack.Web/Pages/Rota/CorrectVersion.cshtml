@page
@using NodaTime
@model CorrectVersionModel
@{
	ViewData["Title"] = "Correct rota version";
}

<div class="jt-page-narrow">
	<div class="jt-page-head">
		<h1>Correct rota version</h1>
	</div>

	<partial name="_ErrorAlert" model="Model.ErrorMessage"/>

	@if (Model.Version is not null) {
		<form method="post" class="jt-form-card">
			<input type="hidden" asp-for="UserId"/>
			<input type="hidden" asp-for="VersionId"/>
			<div class="form-group">
				<label asp-for="Input.EffectiveStart"></label>
				<input asp-for="Input.EffectiveStart" type="date" class="form-control"/>
				<span asp-validation-for="Input.EffectiveStart" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="Input.EffectiveEnd">Effective end (leave blank if still current)</label>
				<input asp-for="Input.EffectiveEnd" type="date" class="form-control"/>
			</div>
			<div class="form-group">
				<label asp-for="Input.IanaTimeZone"></label>
				<input asp-for="Input.IanaTimeZone" class="form-control"/>
				<span asp-validation-for="Input.IanaTimeZone" class="text-danger"></span>
			</div>

			<h4>Weekly working intervals (leave a slot's day blank to skip it)</h4>
			@for (var i = 0; i < Model.Input.WeeklyIntervals.Count; i++) {
				<fieldset>
					<legend>Interval @(i + 1)</legend>
					<div class="form-group">
						<label asp-for="Input.WeeklyIntervals[i].Day"></label>
						<select asp-for="Input.WeeklyIntervals[i].Day" class="form-control"
						        asp-items="Html.GetEnumSelectList<IsoDayOfWeek>()">
							<option value="">-- none --</option>
						</select>
					</div>
					<div class="form-group">
						<label asp-for="Input.WeeklyIntervals[i].Start"></label>
						<input asp-for="Input.WeeklyIntervals[i].Start" class="form-control"/>
					</div>
					<div class="form-group">
						<label asp-for="Input.WeeklyIntervals[i].End"></label>
						<input asp-for="Input.WeeklyIntervals[i].End" class="form-control"/>
					</div>
				</fieldset>
			}

			<div class="form-group">
				<label asp-for="Input.Reason">Reason for this correction</label>
				<input asp-for="Input.Reason" class="form-control"/>
				<span asp-validation-for="Input.Reason" class="text-danger"></span>
			</div>
			<div class="jt-toolbar d-flex flex-wrap gap-2 align-items-center">
				<button type="submit" class="btn btn-primary">Save</button>
				<a class="btn btn-secondary" asp-page="/Rota/Index" asp-route-userId="@Model.UserId">Cancel</a>
			</div>
		</form>
	}
</div>
