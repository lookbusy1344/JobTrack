@page
@using JobTrack.Domain.Schedules
@model CorrectExceptionModel
@{
	ViewData["Title"] = "Correct rota exception";
}

<div class="jt-page-narrow">
	<div class="jt-page-head">
		<p class="jt-eyebrow">Working time</p>
		<h1>Correct rota exception</h1>
	</div>

	<partial name="_ErrorAlert" model="Model.ErrorMessage"/>

	@if (Model.Exception is not null) {
		<form method="post" class="jt-form-card">
			<input type="hidden" asp-for="UserId"/>
			<input type="hidden" asp-for="ExceptionId"/>
			<div class="form-group">
				<label asp-for="Input.Effect"></label>
				<select asp-for="Input.Effect" class="form-control" asp-items="EnumDisplay.BuildOptions<ScheduleExceptionEffect>()"></select>
			</div>
			<div class="form-group">
				<label asp-for="Input.Start"></label>
				<input asp-for="Input.Start" class="form-control"/>
				<span asp-validation-for="Input.Start" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="Input.End"></label>
				<input asp-for="Input.End" class="form-control"/>
				<span asp-validation-for="Input.End" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="Input.RateOverride">Rate override (only valid for AddWorkingTime)</label>
				<input asp-for="Input.RateOverride" class="form-control"/>
			</div>
			<div class="form-group">
				<label asp-for="Input.Reason">Reason for this correction</label>
				<input asp-for="Input.Reason" class="form-control"/>
				<span asp-validation-for="Input.Reason" class="text-danger"></span>
			</div>
			<div class="jt-toolbar jt-toolbar--flush">
				<button type="submit" class="btn btn-primary">Save</button>
				<a class="btn btn-secondary" asp-page="/Rota/Index" asp-route-userId="@Model.UserId">Cancel</a>
			</div>
		</form>
	}
</div>
