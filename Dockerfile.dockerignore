# Build context here is the monorepo root (VSStuff/), not JobTrack/ — see the Dockerfile header
# comment for why. Everything is ignored by default except .editorconfig and the JobTrack/ subtree
# actually needed to build the three published apphosts (Web, Database, AdminCli); other sibling
# monorepo projects (EnrolmentRules/, etc.) are irrelevant to this image and excluded to keep the
# build context small.
*
!.editorconfig
!JobTrack/

# Build output and caches — rebuilt inside the image.
JobTrack/**/bin/
JobTrack/**/obj/
JobTrack/TestResults/

# LibMan-restored client libs (gitignored; restored during the build).
JobTrack/src/JobTrack.Web/wwwroot/lib/

# Not needed to build/run the published apps; keeps the build context small.
JobTrack/tests/
JobTrack/spikes/
JobTrack/scripts/
JobTrack/docs/

# Sample *projects* are irrelevant to the image and large, so exclude them individually — but keep
# samples/job-tree-imports/ (small JSON seed trees), which the demo seed step imports as the demo
# account at build time. Excluding these by name rather than all of samples/ sidesteps Docker's
# "cannot re-include a file whose parent directory is excluded" rule.
JobTrack/samples/JobTrack.ExternalApiClient/
JobTrack/samples/JobTrack.Sample.PostgreSql/
JobTrack/samples/JobTrack.Sample.Sqlite/
JobTrack/samples/JobTrack.UatSeed/

# SQLite/Postgres scratch data and dev-only artifacts.
JobTrack/*.db
JobTrack/*.db-shm
JobTrack/*.db-wal
JobTrack/jobtrack-web-dev.db*

# IDE / OS / VCS noise.
JobTrack/.git/
JobTrack/.github/
JobTrack/.idea/
JobTrack/.vs/
JobTrack/.vscode/
JobTrack/.cursor/
JobTrack/.claude/
JobTrack/**/*.user
JobTrack/**/.DS_Store
